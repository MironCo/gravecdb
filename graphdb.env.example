# GraphDB Configuration Example
# Copy this file to .env and customize for your environment

# =============================================================================
# Option 1: Single DSN (recommended)
# =============================================================================
# Format: graphdb://[username:password@][host][:port]/[datadir]?[options]

# Development (no auth, local data)
GRAPHDB_DSN=graphdb:///data

# Production with auth
# GRAPHDB_DSN=graphdb://admin:supersecretpassword@0.0.0.0:8080/data

# With Ollama embeddings
# GRAPHDB_DSN=graphdb://admin:secret@:8080/data?embedder=ollama://localhost:11434/nomic-embed-text

# With OpenAI embeddings
# GRAPHDB_DSN=graphdb://admin:secret@:8080/data?embedder=openai://

# In-memory only (no persistence)
# GRAPHDB_DSN=graphdb://:memory:

# =============================================================================
# Option 2: Individual environment variables
# =============================================================================
# These override values in DSN or provide defaults

# Authentication
# GRAPHDB_USERNAME=admin
# GRAPHDB_PASSWORD=supersecretpassword

# Storage
# GRAPHDB_DATA_DIR=./data

# Server
# GRAPHDB_HOST=0.0.0.0
# GRAPHDB_PORT=8080

# Embeddings (for semantic search)
# EMBEDDER_URL=ollama://localhost:11434/nomic-embed-text
# EMBEDDER_URL=openai://

# OpenAI API key (required if using openai:// embedder)
# OPENAI_API_KEY=sk-...

# =============================================================================
# Embedder URL Examples
# =============================================================================
# Ollama (local):
#   ollama://localhost:11434/nomic-embed-text
#   ollama://localhost/mxbai-embed-large
#   ollama://                                  (defaults: localhost:11434, nomic-embed-text)
#
# OpenAI:
#   openai://                                  (uses OPENAI_API_KEY env var)
#   openai://sk-xxx@api.openai.com/text-embedding-3-large
